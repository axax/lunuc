{
  "types": [
    {
      "access": {
        "create": {
          "capability": "admin_options"
        }
      },
      "name": "Api",
      "entryClonable": true,
      "fields": [
        {
          "tab": "elements.generalTab",
          "name": "name",
          "required": true,
          "clone": "${name} (copy)",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "slug",
          "required": true,
          "clone": "${name}/copy",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "mimeType",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "active",
          "type": "Boolean",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "script",
          "uitype": "jseditor",
          "alwaysLoad": false
        },
        {
          "tab": "Api.securityTab",
          "name": "apiToken",
          "type": "ApiToken",
          "multi": true
        },
        {
          "tab": "Api.securityTab",
          "name": "basicAuth",
          "type": "Boolean",
          "newLine": true,
          "separator": true,
          "hideColumnInTypes": true,
          "index": 1
        },
        {
          "tab": "Api.securityTab",
          "name": "baUser",
          "hideColumnInTypes": true,
          "index": 1
        },
        {
          "tab": "Api.securityTab",
          "name": "baPassword",
          "uitype": "password",
          "hideColumnInTypes": true,
          "hash": true
        },
        {
          "tab": "elements.generalTab",
          "name": "workerThread",
          "type": "Boolean",
          "hideColumnInTypes": true,
          "label": "Run in Worker-Thread",
          "index": 1
        }
      ]
    },
    {
      "name": "ApiToken",
      "entryClonable": false,
      "fields": [
        {
          "tab": "elements.generalTab",
          "name": "name",
          "required": true,
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "token",
          "required": true,
          "uiReadOnly": true,
          "defaultValue": "$TOKEN",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "expires",
          "type": "Float",
          "uitype": "datetime",
          "index": 1
        },
        {
          "tab": "elements.generalTab",
          "name": "scopes",
          "type": "Object",
          "uitype": "json",
          "hideColumnInTypes": true,
          "index": 1
        }
      ]
    }
  ]
}
